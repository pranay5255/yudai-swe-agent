# ============================================================================
# LLM API KEYS + MODEL SETTINGS
# ============================================================================

# OpenRouter (used by security_fix_openrouter.yaml)
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Examples: anthropic/claude-3.5-sonnet, openai/gpt-4o, google/gemini-pro
OPENROUTER_MODEL_NAME=anthropic/claude-3.5-sonnet

# Direct provider keys (for Litellm/OpenAI/Anthropic usage)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Generic defaults (used by mini-swe-agent if set)
# Example: claude-sonnet-4-20250514, gpt-4o-mini, deepseek/deepseek-coder
MSWEA_MODEL_NAME=
# Optional generic API key (used by some providers via MSWEA_MODEL_API_KEY)
MSWEA_MODEL_API_KEY=

# Optional: Cost tracking mode (default or ignore_errors for free/local models)
# MSWEA_COST_TRACKING=ignore_errors

# ============================================================================
# RPC ENDPOINTS (ARCHIVE REQUIRED FOR HISTORICAL FORKS)
# ============================================================================

# Active fork RPC used by anvil/forge/cast (set this per run)
ETH_RPC_URL=

# Convenience slots for multiple chains (set ETH_RPC_URL to the one you need)
MAINNET_RPC_URL=
BSC_RPC_URL=
BASE_RPC_URL=

# ============================================================================
# FOUNDRY / ON-CHAIN SETTINGS
# ============================================================================

# Hardfork rules (optional): shanghai, cancun
# FOUNDRY_EVM_VERSION=shanghai

# Etherscan API (verification or metadata fetching)
ETHERSCAN_API_KEY=

# Optional RPC provider keys (used to build ETH_RPC_URL)
ALCHEMY_API_KEY=
INFURA_API_KEY=

# Transaction signing (DO NOT COMMIT REAL KEYS)
PRIVATE_KEY=0x

# ============================================================================
# EXPLOIT GENERATION - BENCHMARK V3 (run_benchmark_exploit_v3.py)
# ============================================================================
# These control the benchmark harness. Override via CLI flags or env vars.
# CLI flags always take precedence over env vars.

# Agent YAML config to use (resolved relative to src/minisweagent/config/ or as an absolute path)
# Default: benchmark_exploit_v3.yaml  |  CLI: --config
EXPLOIT_CONFIG_V3=benchmark_exploit_v3.yaml

# Directory where episode trajectories + result JSONs are written
# Default: exploit_results_v3  |  CLI: --output
EXPLOIT_OUTPUT_DIR_V3=exploit_results_v3

# Docker image that runs the Foundry/Anvil environment inside the episode
# Must be built and available locally (docker images | grep yudai-base)
# Default: yudai-base:latest  |  CLI: --image
EXPLOIT_DOCKER_IMAGE=yudai-base:latest

# Max USD spend per episode before the agent is stopped
# Default: 20.0  |  CLI: --cost-limit
EXPLOIT_COST_LIMIT_V3=20.0

# Player EOA that receives funds and runs the exploit
# Default: 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266 (Anvil account #0)  |  hardcoded fallback
PLAYER_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# Starting balance given to the player on the forked chain (in wei)
# Default: 100000000000000000000000 (100k ETH)
PLAYER_BALANCE_WEI=100000000000000000000000

# ============================================================================
# EXPLOIT GENERATION - LOCAL SINGLE EPISODE (legacy / foundry_exploit.yaml)
# ============================================================================

# Local contract path for exploit tests
EXPLOIT_CONTRACT_PATH=contracts/SimpleBank.sol

# Agent config for exploit runs
EXPLOIT_CONFIG=foundry_exploit.yaml
EXPLOIT_OUTPUT_DIR=exploit_results
EXPLOIT_COST_LIMIT=5.0

# Anvil settings
ANVIL_PORT=8545
# Optional fork settings (set ETH_RPC_URL or EXPLOIT_FORK_URL for forks)
EXPLOIT_FORK_URL=
EXPLOIT_FORK_BLOCK=

# Keys/addresses for deployment
DEPLOYER_PRIVATE_KEY=0x
