# =============================================================================
# FAST DEV DOCKERFILE - FOR QUICK ITERATION
# =============================================================================
# This version SKIPS Mythril and multiple solc versions for faster builds.
# Build time: ~3-5 minutes instead of 12-20 minutes
#
# Build: docker build -t yudai-base:fast -f docker/Dockerfile.base-fast .
# =============================================================================

FROM ghcr.io/foundry-rs/foundry:latest

SHELL ["/bin/bash", "-lc"]

USER root

# Version arguments
ARG SLITHER_VERSION=0.10.2
ARG SOLC_VERSION=0.8.24
ARG ECHIDNA_VERSION=2.2.5
ARG PYTHON_VERSION=3.12

# Environment variables
ENV DEBIAN_FRONTEND=noninteractive \
    VENV_MAIN=/opt/venv-main \
    UV_PYTHON=${PYTHON_VERSION} \
    FOUNDRY_DISABLE_NIGHTLY_WARNING=1 \
    PATH="${VENV_MAIN}/bin:/root/.solc-select:/root/.cargo/bin:/root/.local/bin:${PATH}"

# Install system dependencies including Python 3.12
RUN echo "[$(date +%T)] Starting system dependencies installation..." \
    && apt-get update && apt-get install -y --no-install-recommends \
      software-properties-common \
      ca-certificates \
      curl \
      wget \
      git \
      unzip \
      build-essential \
      pkg-config \
      libssl-dev \
      libffi-dev \
      gnupg \
    && add-apt-repository ppa:deadsnakes/ppa -y --no-update \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
      python${PYTHON_VERSION} \
      python${PYTHON_VERSION}-venv \
      python${PYTHON_VERSION}-dev \
    && rm -rf /var/lib/apt/lists/* \
    && echo "[$(date +%T)] System dependencies installed"

# Install uv package manager
RUN echo "[$(date +%T)] Installing uv package manager..." \
    && curl -LsSf https://astral.sh/uv/install.sh | sh \
    && echo "[$(date +%T)] uv installed"

# Create main virtual environment using uv for Slither and other tools
RUN echo "[$(date +%T)] Creating main venv and installing Slither..." \
    && uv venv "${VENV_MAIN}" --python ${PYTHON_VERSION} \
    && . "${VENV_MAIN}/bin/activate" \
    && uv pip install "slither-analyzer==${SLITHER_VERSION}" \
    && uv pip install solc-select \
    && echo "[$(date +%T)] Slither and solc-select installed"

# Install only the main solc version (skip other versions for speed)
RUN echo "[$(date +%T)] Installing solc ${SOLC_VERSION}..." \
    && . "${VENV_MAIN}/bin/activate" \
    && solc-select install "${SOLC_VERSION}" \
    && solc-select use "${SOLC_VERSION}" \
    && ln -sf /root/.solc-select/solc /usr/local/bin/solc \
    && echo "[$(date +%T)] Solc installed"

# Install Echidna
ARG TARGETARCH
RUN echo "[$(date +%T)] Installing Echidna..." \
    && case "${TARGETARCH}" in \
      amd64) echidna_arch="x86_64" ;; \
      arm64) echidna_arch="aarch64" ;; \
      *) echo "Unsupported arch: ${TARGETARCH}" && exit 1 ;; \
    esac \
    && curl -fsSL -o /tmp/echidna.tar.gz \
         "https://github.com/crytic/echidna/releases/download/v${ECHIDNA_VERSION}/echidna-${ECHIDNA_VERSION}-${echidna_arch}-linux.tar.gz" \
    && tar -xzf /tmp/echidna.tar.gz -C /tmp \
    && install -m 0755 /tmp/echidna /usr/local/bin/echidna \
    && install -m 0755 /tmp/echidna /usr/local/bin/echidna-test \
    && rm -rf /tmp/echidna.tar.gz /tmp/echidna \
    && echo "[$(date +%T)] Echidna installed"

# Verify tools
RUN echo "=== Testing Tools ===" \
    && forge --version \
    && . "${VENV_MAIN}/bin/activate" && slither --version \
    && echidna-test --version \
    && echo "=== All tools verified successfully ==="

WORKDIR /workspace

LABEL maintainer="yudai-team"
LABEL description="Yudai FAST dev image (no Mythril, no Aderyn, fewer solc versions)"
LABEL image.type="dev-fast"
LABEL tools="forge,cast,anvil,slither,echidna,solc,uv"
