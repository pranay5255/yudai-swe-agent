FROM yudai-base:latest

WORKDIR /templates/sol-0.8-standalone

# Ensure solc 0.8.20 is active
RUN . "${VENV_MAIN}/bin/activate" \
    && solc-select use 0.8.20

# Initialize a Foundry project with no git
RUN forge init --no-commit . \
    && rm -f src/Counter.sol test/Counter.t.sol script/Counter.s.sol

# Write a minimal 0.8.20-compatible contract as starting point
RUN echo 'pragma solidity ^0.8.20;\n\ncontract Template {\n    address public owner;\n\n    constructor() {\n        owner = msg.sender;\n    }\n}' > src/Template.sol

# Verify template builds
RUN forge build

WORKDIR /workspace

LABEL description="Yudai template: Solidity 0.8.x standalone"
LABEL solc.version="0.8.20"
